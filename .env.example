# ----------------------------------------------------------------------
# GA4 Measurement ID (format: G-XXXXXXXXXX)
#
# NOTE: the property ID "14397548470" is NOT the same as the Measurement ID.
#       You can find the Measurement ID in GA4:
#       Admin → Data Streams → Web → [your stream] → Measurement ID
#
# If not set, the app falls back to "G-14397548470" (placeholder — replace it).
# ----------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
